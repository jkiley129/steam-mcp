# Get your API key at: https://steamcommunity.com/dev/apikey
STEAM_API_KEY=your_api_key_here

# Your Steam ID — accepts either:
#   - 64-bit numeric ID (e.g., 76561198012345678)
#   - Vanity URL username (e.g., "myusername" from steamcommunity.com/id/myusername)
STEAM_ID=your_steam_id_or_vanity_url

# Optional: override cache directory (default: ~/.steam-mcp/cache/)
# STEAM_MCP_CACHE_DIR=/custom/cache/path
